{
  "extends": "../../tsconfig.json",
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "CommonJS",
      "verbatimModuleSyntax": false,
      "rootDir": ".",
    },
  },
  "compilerOptions": {
    "types": [
      "node",
      "webdriverio/async",
      "@wdio/globals/types",
      "@wdio/mocha-framework",
      "expect-webdriverio",
      "wdio-vscode-service",
    ],
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules"],
}
